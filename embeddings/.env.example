# Copy to .env and tweak. docker-compose reads this automatically.
DB_USER=codegraph
DB_PASSWORD=codegraph
DB_NAME=codegraph
DB_PORT=5432

# Any Ollama-registry embedding model. nomic-embed-text is 768 dim and
# code-aware. Other options:
#   mxbai-embed-large      (1024 dim — change EMBED_DIM accordingly)
#   all-minilm             (384 dim)
# Note: Jina v2 base code is not on the official Ollama registry.
OLLAMA_MODEL=nomic-embed-text
EMBED_DIM=768

INDEXER_PORT=8088
EMBEDDINGS_API_AUTH=

# Neo4j (call-graph store)
NEO4J_USER=neo4j
NEO4J_PASSWORD=codegraph
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
# Path to graph.jsonl inside the indexer container. Compose mounts
# `../.codegraph` → `/data` so the default just works after `codegraph build`.
CODEGRAPH_GRAPH_PATH=/data/graph.jsonl

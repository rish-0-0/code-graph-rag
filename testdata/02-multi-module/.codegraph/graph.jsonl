{"type":"schema","schema":{"version":"1","nodeKinds":[{"name":"Workspace","doc":"A go.work workspace grouping modules"},{"name":"Module","doc":"A Go module discovered on disk (has a go.mod)"},{"name":"ModuleVersion","doc":"A referenced module + version string; may be unresolved (external) or resolve to a local Module"},{"name":"Package","doc":"A Go package (importable)"},{"name":"File","doc":"A single .go file"},{"name":"Import","doc":"An external (unresolved) import path referenced by a package"},{"name":"Type","doc":"A named type (struct, alias, named)"},{"name":"Interface","doc":"An interface type"},{"name":"Field","doc":"A field of a struct type"},{"name":"Function","doc":"A top-level function"},{"name":"Method","doc":"A method (function with receiver)"},{"name":"Receiver","doc":"Receiver declaration of a method"},{"name":"Param","doc":"Parameter of a function/method"},{"name":"Result","doc":"Result (return) of a function/method"},{"name":"Variable","doc":"Package-level variable"},{"name":"Constant","doc":"Package-level constant"},{"name":"TypeParam","doc":"Generic type parameter"},{"name":"Literal","doc":"Notable literal value"}],"edgeKinds":[{"name":"CONTAINS","doc":"Parent → child containment (module→package, package→file, file→symbol)"},{"name":"DECLARES","doc":"File → symbol declaration"},{"name":"IMPORTS","doc":"Package → import target (external Import node OR local Package node)"},{"name":"CALLS","doc":"Function/Method → the Function/Method it invokes (with call-site position)"},{"name":"REFERENCES","doc":"Generic symbol reference that is not a call"},{"name":"IMPLEMENTS","doc":"Type → Interface it satisfies"},{"name":"EMBEDS","doc":"Type embeds another type"},{"name":"HAS_METHOD","doc":"Type → its method"},{"name":"HAS_FIELD","doc":"Type → its field"},{"name":"HAS_PARAM","doc":"Function → param"},{"name":"RETURNS","doc":"Function → result"},{"name":"OF_TYPE","doc":"Symbol → its declared type"},{"name":"ASSIGNS","doc":"Assignment edge"},{"name":"INSTANTIATES","doc":"Generic → concrete instantiation"},{"name":"SATISFIES_CONSTRAINT","doc":"Type → type constraint it satisfies"},{"name":"READS","doc":"Function/Method → variable or chan it reads"},{"name":"WRITES","doc":"Function/Method → variable or chan it writes"},{"name":"REQUIRES","doc":"Module → ModuleVersion in its require block"},{"name":"REPLACES","doc":"Module → ModuleVersion or Module target of a replace directive"},{"name":"RESOLVES_TO","doc":"ModuleVersion → local Module it was resolved to"},{"name":"WORKSPACES","doc":"Workspace → Module member via go.work"}],"idConventions":{"Field":"\u003ctypeID\u003e.\u003cFieldName\u003e","File":"file:\u003cabsolutePath\u003e","Function":"\u003cpackageID\u003e.\u003cName\u003e","Import":"imp:\u003cpackageID\u003e-\u003e\u003cimportPath\u003e","Method":"\u003cpackageID\u003e.\u003cTypeName\u003e.\u003cMethodName\u003e","Module":"mod:\u003cpath\u003e@\u003cversion\u003e","ModuleVersion":"mod:\u003cpath\u003e@\u003cversion\u003e  (version may be '*' if unspecified)","Package":"pkg:\u003cmodulePath\u003e@\u003cversion\u003e/\u003cimportPath\u003e","Type":"\u003cpackageID\u003e.\u003cName\u003e"},"sampleQueries":[{"name":"direct callers of a function","cypher":"MATCH (c)-[:CALLS]-\u003e(f {name:\"ExportedFn\"}) RETURN c.id"},{"name":"everything a package exports that nothing inside the module calls","cypher":"MATCH (p:Package {importPath:\"example.com/mod/pkg\"})-[:CONTAINS]-\u003e(sym) WHERE NOT ( ()-[:CALLS|REFERENCES]-\u003e(sym) ) RETURN sym.id"},{"name":"types implementing an interface","cypher":"MATCH (t)-[:IMPLEMENTS]-\u003e(i:Interface {name:\"Talker\"}) RETURN t.id"},{"name":"cross-module calls (caller module != callee module)","cypher":"MATCH (caller)-[:CALLS]-\u003e(callee), (mA:Module)-[:CONTAINS*1..3]-\u003e(caller), (mB:Module)-[:CONTAINS*1..3]-\u003e(callee) WHERE mA \u003c\u003e mB RETURN mA.path, mB.path, caller.id, callee.id"},{"name":"replace-resolved module links","cypher":"MATCH (m:Module)-[:REPLACES]-\u003e(target) RETURN m.path, target.path"}]}}
